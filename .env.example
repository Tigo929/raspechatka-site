# ─── Public site ─────────────────────────────────────────────────────────────

# Публичный URL сайта без завершающего слеша.
# Используется для canonical, sitemap и Open Graph.
# В production сервер не запустится без корректного значения.
NEXT_PUBLIC_SITE_URL=https://your-domain.ru

# Номер счётчика Яндекс Метрики (только цифры).
# Без этой переменной счётчик не подключается — приложение работает в штатном режиме.
# Найти: https://metrika.yandex.ru → Настройки счётчика → Номер счётчика.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# ─── Telegram delivery ───────────────────────────────────────────────────────

# Telegram-бот для доставки заявок.
# Без токена и chat ID заявки сохраняются на сервере, но уведомления не приходят.
# Создать бота: @BotFather → /newbot. Chat ID получить через @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Admin ───────────────────────────────────────────────────────────────────

# Пароль для входа в /admin (минимум 12 символов).
# Без него login API вернёт 503.
ADMIN_PASSWORD=replace-with-a-strong-password-12chars

# HMAC-секрет для подписи сессионных токенов (минимум 32 символа).
# Без него /admin полностью недоступен — ни cookie, ни токен не принимаются.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-64-hex-chars-minimum-32-symbols-required

# ─── Storage ─────────────────────────────────────────────────────────────────

# Путь для хранения заявок и аналитики.
# По умолчанию — ./data/ в корне проекта.
# На production рекомендуется указать путь вне директории проекта.
PRINTLAB_DATA_DIR=

# ─── Outbox cron ─────────────────────────────────────────────────────────────

# Секрет для защиты эндпоинта повторной доставки заявок.
# Cron вызывает POST /api/internal/delivery-outbox/process с заголовком x-outbox-secret.
# Nginx блокирует /api/internal/ снаружи — эндпоинт доступен только с 127.0.0.1.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OUTBOX_CRON_SECRET=

# ─── PostgreSQL (Этап 4A+) ───────────────────────────────────────────────────

# Строка подключения к PostgreSQL для Prisma ORM.
# Активна только при DATA_BACKEND=postgres.
# Локальный дев: postgresql://raspechatka_dev:password@localhost:5432/raspechatka_dev
# Production (Managed PostgreSQL): задать на сервере, не коммитить.
# При использовании PgBouncer: для запуска миграций используйте прямую строку
# подключения (минуя пулер), запуская prisma migrate с DATABASE_URL=<direct-url>.
DATABASE_URL=

# ─── Data backend feature flag ────────────────────────────────────────────────

# Управляет активным хранилищем данных.
# json     — текущий JSON-режим (default). Production продолжает работать без изменений.
# postgres — PostgreSQL через Prisma. Активировать только после Этапа 4B–4C.
DATA_BACKEND=json

# ─── Redis (Этап 4D) ─────────────────────────────────────────────────────────

# URL подключения к Redis для BullMQ и rate limiting.
# Активно только при наличии BullMQ-зависимости (Этап 4D).
# Локальный дев: redis://localhost:6379
REDIS_URL=

# ─── S3 / MinIO (Этап 4E) ────────────────────────────────────────────────────

# Эндпоинт S3-совместимого хранилища (Timeweb S3 / MinIO).
S3_ENDPOINT=
# Регион: ru-1 (Timeweb) или us-east-1 (MinIO по умолчанию).
S3_REGION=
# Имя бакета для хранения файлов заявок.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# true для MinIO (path-style), false для AWS S3.
S3_FORCE_PATH_STYLE=

# ─── Мониторинг / Sentry (Этап 4F) ──────────────────────────────────────────

SENTRY_DSN=
SENTRY_ENVIRONMENT=

# ─── Retention политики (Этап 4F) ────────────────────────────────────────────

# Количество дней хранения файлов заявок. По умолчанию: 90.
ORDER_FILE_RETENTION_DAYS=
# Количество дней хранения аналитических событий. По умолчанию: 365.
ANALYTICS_RETENTION_DAYS=
