{
  "name": "raspechatka-site",
  "version": "1.0.0",
  "private": true,
  "description": "«Распечатка» — коммерческий сайт студии печати на футболках на Next.js.",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:import-json:dry": "node --experimental-strip-types --no-warnings scripts/migrate-json-to-postgres.ts --dry-run --fixture",
    "db:import-json": "node --experimental-strip-types --no-warnings scripts/migrate-json-to-postgres.ts --fixture"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.456.0",
    "motion": "^12.40.0",
    "next": "^16.2.7",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.35.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.7",
    "postcss": "8.5.15",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
