# Переменные для локального Docker Compose (docker-compose.dev.yml).
# Скопируйте в .env.docker и не коммитьте этот файл.
# Используются только для docker-compose — приложение читает .env.local.

POSTGRES_USER=raspechatka_dev
POSTGRES_PASSWORD=your_strong_local_password_here
POSTGRES_DB=raspechatka_dev

REDIS_PASSWORD=your_redis_password_here

MINIO_ROOT_USER=raspechatka_dev
MINIO_ROOT_PASSWORD=your_minio_password_here
